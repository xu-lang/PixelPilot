<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <layer-list>
            <item>
                <shape>
                    <solid android:color="@color/openipc_panel_selected" />
                    <corners android:radius="9dp" />
                </shape>
            </item>
            <item android:gravity="left|center_vertical" android:width="3dp" android:height="22dp">
                <shape>
                    <solid android:color="@color/openipc_accent" />
                    <corners android:radius="2dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/openipc_nav_hover" />
            <corners android:radius="9dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="#00000000" />
            <corners android:radius="9dp" />
        </shape>
    </item>
</selector>

<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape>
            <solid android:color="#00000000" />
            <stroke android:width="1dp" android:color="@color/openipc_stroke_soft" />
            <corners android:radius="9dp" />
            <padding android:left="12dp" android:top="8dp" android:right="12dp" android:bottom="8dp" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/openipc_button_pressed" />
            <stroke android:width="1dp" android:color="@color/openipc_accent" />
            <corners android:radius="9dp" />
            <padding android:left="12dp" android:top="8dp" android:right="12dp" android:bottom="8dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/openipc_button" />
            <stroke android:width="1dp" android:color="@color/openipc_button_stroke" />
            <corners android:radius="9dp" />
            <padding android:left="12dp" android:top="8dp" android:right="12dp" android:bottom="8dp" />
        </shape>
    </item>
</selector>

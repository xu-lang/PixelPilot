<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape>
            <solid android:color="@color/openipc_field_focus" />
            <stroke android:width="1dp" android:color="@color/openipc_accent" />
            <corners android:radius="10dp" />
            <padding android:left="10dp" android:top="4dp" android:right="10dp" android:bottom="4dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/openipc_field" />
            <stroke android:width="1dp" android:color="@color/openipc_stroke" />
            <corners android:radius="10dp" />
            <padding android:left="10dp" android:top="4dp" android:right="10dp" android:bottom="4dp" />
        </shape>
    </item>
</selector>
